{
  "Urls": "http://+:50900",

  "ApplicationName": "callee-service",

  "Swagger": {
    "AlwaysInclude": true
  },

  "Otel": {
    "Exporter": {
      "Otlp": {
        "Traces": {
          "Endpoint": "http://localhost:4317"
        }
      }
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "OpenTelemetry": "Error"
      }
    }
  },

  "AllowedHosts": "*"
}
