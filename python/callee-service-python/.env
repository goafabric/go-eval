# Equivalent of application.properties
# All values here are defaults — override via real env vars in production

APP_NAME=callee-service
PORT=50900

# Health
HEALTH_PATH=/actuator/health

# Metrics
PROMETHEUS_PATH=/actuator/prometheus

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENABLED=true

# Logging
LOG_LEVEL=INFO
